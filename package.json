{
  "name": "ai-incident-dashboard",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev:api": "dotnet run --project backend/AiIncident.Api --urls http://localhost:5087",
    "dev:web": "ng serve",
    "dev:full": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npx vitest run",
    "test:ci": "ng test --no-watch",
    "codegen": "graphql-codegen --config codegen.ts",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\" \"*.md\"",
    "serve:ssr:ai-incident-dashboard": "node dist/ai-incident-dashboard/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.9",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.9",
    "@apollo/client": "^4.1.9",
    "@ngrx/signals": "^21.1.0",
    "apollo-angular": "^13.0.0",
    "express": "^5.1.0",
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/typed-document-node": "^7.0.0",
    "@graphql-codegen/typescript": "^6.0.0",
    "@graphql-codegen/typescript-apollo-angular": "^5.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.0",
    "@testing-library/angular": "^19.2.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "msw": "^2.14.2",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.0.8"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}